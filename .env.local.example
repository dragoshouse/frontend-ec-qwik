# Firestore REST API Configuration
# These values are already set in src/lib/firestore-rest.ts
# Uncomment and update if needed (not recommended for production)

# VITE_FIREBASE_PROJECT_ID=catallog-experiences
# VITE_FIREBASE_API_KEY=your-api-key-here

# Environment (development/production/staging)
# VITE_ENV=development

# Optional: Firebase hosting URL
# VITE_FIREBASE_HOSTING_URL=https://catallog-experiences.web.app
