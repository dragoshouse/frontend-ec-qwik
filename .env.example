# Firebase Firestore REST API Configuration
# These are PUBLIC and SAFE to commit (restricted by Firestore Security Rules)
# 
# Get PROJECT_ID from: Firebase Console > Project Settings
# Get API_KEY from: Firebase Console > Project Settings > Web API Key
#
# Security Note:
# - The API key is restricted by Firestore Security Rules (read-only)
# - No sensitive data should be accessible with this key
# - Requests are limited by Firebase quotas
#
# Usage:
# 1. Copy this file to .env.local
# 2. Fill in your Firebase project values
# 3. Start the dev server: npm start
# 4. Or deploy: npm run deploy

# Firestore Project ID
VITE_FIREBASE_PROJECT_ID=catallog-experiences

# Firestore REST API Key (read-only, protected by Security Rules)
VITE_FIREBASE_API_KEY=AIzaSyB7Q-zNPFBeHwRXCtv6-aWghTMExXh_GDI

# Optional: Firebase Hosting URL (for production redirects)
# VITE_FIREBASE_HOSTING_URL=https://catallog-experiences.web.app

# Optional: Custom Firestore REST endpoint (usually not needed)
# VITE_FIRESTORE_ENDPOINT=https://firestore.googleapis.com/v1

# Environment mode (development / staging / production)
# VITE_ENV=development

